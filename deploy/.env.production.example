# Скопируй на сервер как .env в корне проекта:
# cp deploy/.env.production.example .env

# Порт на хосте (80 = http://IP-СЕРВЕРА)
APP_PORT=80

# Пароль PostgreSQL
POSTGRES_PASSWORD=замени-на-сложный-пароль

# Секрет для JWT (длинная случайная строка)
JWT_SECRET_KEY=замени-на-длинный-секрет-минимум-32-символа

# URL сайта для CORS (если есть домен)
# CORS_ORIGINS=http://123.45.67.89,https://tco.example.ru

# Учётная запись администратора (создаётся при первом запуске)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin12345!
